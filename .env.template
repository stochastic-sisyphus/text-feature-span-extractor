# =============================================================================
# Environment Configuration
# =============================================================================
# Copy to .env and fill in values before running.

# --- Pipeline ---
INVOICEX_LOG_LEVEL=INFO
INVOICEX_LOG_FORMAT=json
MODEL_ID=unscored-baseline

# --- Storage backends (local | blob) ---
INVOICEX_STORAGE_BACKEND=local
INVOICEX_DOCUMENT_SOURCE=local
INVOICEX_OUTPUT_BACKEND=local

# --- Pipeline tuning ---
INVOICEX_NONE_BIAS=0.05
INVOICEX_CONFIDENCE_AUTO_APPROVE=0.85
INVOICEX_ML_SCORE_WEIGHT=0.7
INVOICEX_USE_RANKER=false

# --- API ---
INVOICEX_API_KEY=REPLACE_WITH_API_KEY
INVOICEX_CORS_ORIGINS=http://localhost:3000

# --- MLflow ---
INVOICEX_USE_MLFLOW=false
INVOICEX_MLFLOW_TRACKING_URI=http://mlflow:5000

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=REPLACE_WITH_GRAFANA_PASSWORD

# --- Postgres ---
POSTGRES_USER=YOUR_POSTGRES_USER
POSTGRES_PASSWORD=REPLACE_WITH_POSTGRES_PASSWORD
POSTGRES_DB=YOUR_POSTGRES_DB

# --- Azure (only needed when backends != local) ---
# AZURE_TENANT_ID=YOUR_AZURE_TENANT_ID
# AZURE_CLIENT_ID=YOUR_AZURE_CLIENT_ID
# AZURE_CLIENT_SECRET=REPLACE_WITH_AZURE_CLIENT_SECRET
# AZURE_STORAGE_ACCOUNT_NAME=YOUR_STORAGE_ACCOUNT
# SHAREPOINT_SITE_ID=YOUR_SHAREPOINT_SITE_ID
# DATAVERSE_ENVIRONMENT_URL=YOUR_DATAVERSE_URL
